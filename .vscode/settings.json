{
    // we use a json schema to define the structure of the geoconnex metadata
    // this allows us to validate the content both in tests and in
    // real time validation in the editor
    "json.schemas": [
        {
            "fileMatch": [
                "namespaces/**/metadata.json"
            ],
            "url": "./checks/geoconnex_metadata_schema.json"
        }
    ]
}